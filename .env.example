# =============================================================================
# OpenClaw Governor Template — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Run `scripts/init.sh` to auto-replace placeholders across all template files.
# =============================================================================

# --- Target Machine ---
HOSTNAME=my-server
DISTRO="Ubuntu 24.04"
USERNAME=myuser
LAN_IP=192.168.1.100
TAILSCALE_IP=100.x.x.x
NAS_IP=192.168.1.200
NAS_SSH_PORT=22

# --- Hardware ---
GPU_MODEL="RTX 4090"
GPU_VRAM=24GB
CPU_MODEL="AMD Ryzen 9 7950X"
RAM_SIZE=64GB

# --- Agent Configuration ---
AGENT_MAIN=ops-commander
AGENT_WORKER=gpu-runner
AGENT_RESEARCHER=web-scout
PRIMARY_MODEL=claude-sonnet-4
LOCAL_MODEL=llama3-70b

# --- Ports ---
GATEWAY_PORT=18789
INFERENCE_PORT=1234

# --- Notifications ---
TELEGRAM_BOT=@MyBot
TELEGRAM_USER_ID=123456789

# --- Identity ---
EMAIL=user@example.com
GITHUB_USER=myuser
MODEL_DIR=/opt/models
