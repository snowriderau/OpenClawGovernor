# =============================================================================
# OpenClaw Governor — Environment Example
# =============================================================================
# Copy this file to .env and fill in your values, OR run scripts/init.sh
# which will ask questions and write .env for you.
#
# NEVER commit .env — it contains your IPs and credentials.
# This file (.env.example) is safe to commit — it contains only placeholders.
# =============================================================================

# -----------------------------------------------------------------------------
# Machine Identity
# -----------------------------------------------------------------------------

# Hostname of your Linux machine (used in SSH config and agent workspace files)
HOSTNAME=my-linux-box

# Linux username on the machine
USERNAME=youruser

# LAN IP address of the Linux machine
LAN_IP=192.168.1.x

# -----------------------------------------------------------------------------
# Tailscale VPN (optional — delete if not using)
# -----------------------------------------------------------------------------

# Tailscale-assigned IP (100.x.x.x range). Enables access from anywhere.
TAILSCALE_IP=100.x.x.x

# -----------------------------------------------------------------------------
# NAS / Network Storage (optional — delete if not using)
# -----------------------------------------------------------------------------

# IP address of your NAS or secondary storage machine
NAS_IP=192.168.1.x

# SSH port on the NAS (default: 22)
NAS_SSH_PORT=22

# -----------------------------------------------------------------------------
# SSH
# -----------------------------------------------------------------------------

# Path to the SSH private key used to connect to the Linux machine
SSH_KEY_PATH=~/.ssh/id_ed25519

# -----------------------------------------------------------------------------
# Hardware
# -----------------------------------------------------------------------------

# GPU model installed in the Linux machine (used in documentation and diagrams)
GPU=RTX 4090

# -----------------------------------------------------------------------------
# Inference Ports
# -----------------------------------------------------------------------------

# Port that LM Studio or Ollama listens on (OpenAI-compatible API)
# LM Studio default: 1234 | Ollama default: 11434
INFERENCE_PORT=1234

# Port that the Openclaw gateway listens on
GATEWAY_PORT=18789

# -----------------------------------------------------------------------------
# Models
# -----------------------------------------------------------------------------

# Primary cloud model — used by Atlas, Conductor, Forge, Hermes
# Examples: claude-opus-4-5, gpt-4o, claude-3-5-sonnet
PRIMARY_MODEL=claude-opus-4-5

# Local model ID — used by Bolt and Courier (data never leaves the machine)
# Examples: qwen3.5-35b-a3b, nemotron-super-120b-a12b, llama3.3-70b
LOCAL_MODEL=qwen3.5-35b-a3b

# Secondary cloud model — used by Scout, Sentinel (lighter/cheaper)
# Examples: claude-haiku-4-5, gpt-4o-mini
SECONDARY_MODEL=claude-haiku-4-5

# -----------------------------------------------------------------------------
# Agent Names
# -----------------------------------------------------------------------------

# Display name for the orchestrator agent (default: Atlas)
AGENT_MAIN=Atlas

# -----------------------------------------------------------------------------
# Notification Channel — Telegram (optional — delete if not using)
# -----------------------------------------------------------------------------

# Bot token from @BotFather (format: 123456789:ABCdef...)
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (integer). Get it from @userinfobot.
# Only this ID is allowed to send messages to the agent (allowlist policy).
TELEGRAM_USER_ID=

# Bot username shown in Telegram (e.g. @MyAgentBot)
TELEGRAM_BOT=@MyAgentBot

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------

# Your GitHub username (used by Forge for git operations and gh CLI)
GITHUB_USER=your-github-username

# -----------------------------------------------------------------------------
# Email — Hermes agent (optional — delete if not using)
# -----------------------------------------------------------------------------

# Email account the Hermes agent has OAuth access to
# This account must have gog/OAuth credentials configured on the Linux machine
EMAIL=agent@example.com
