# =============================================================================
# OpenClaw Governor — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets and local configuration
# -----------------------------------------------------------------------------

# Environment file — contains IPs, credentials, Telegram tokens
.env

# Openclaw config file — may contain API keys and personal IPs
openclaw.json
.openclaw/

# SSH keys and credentials
*.pem
*.key
id_rsa
id_ed25519
id_ecdsa
*.p12

# -----------------------------------------------------------------------------
# Agent runtime and memory
# -----------------------------------------------------------------------------

# Security audit logs — contain system details (host IPs, service names, etc.)
# These are generated by the security-audit command and should stay local
.agent/memory/audit_*.md

# Session logs and temporary agent state
.agent/sessions/
.agent/tmp/

# -----------------------------------------------------------------------------
# Source reference material
# -----------------------------------------------------------------------------

# Clone of the original linuxlocalai repo used during migration
# Delete this after migration is complete
_source/

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/cache
.pnp.*

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# -----------------------------------------------------------------------------
# OS and editor artifacts
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
.idea/
.vscode/settings.json
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
.temp/
tmp/
